; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BrewDriving"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameStats="*uid://bgoa7j0os3s74"
psx_autoload="uid://u3y0jxl0vtmg"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="BrewDriving"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/psx/plugin.cfg")

[global_group]

zombies="Any of the Zombie Types"
player="The one and only player"

[gui]

theme/default_font_multichannel_signed_distance_field=true

[input]

